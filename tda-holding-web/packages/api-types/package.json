{
  "name": "@tda/api-types",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "openapi-typescript $npm_package_config_api_url -o src/index.ts --immutable",
    "typecheck": "tsc --noEmit"
  },
  "config": {
    "api_url": "http://127.0.0.1:8000/api/v1/openapi.json"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.4",
    "typescript": "^5.6.3"
  }
}
